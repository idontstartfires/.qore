#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["textual>=1.0"]
# ///
"""ruff-tui — interactive browser for ruff lint findings.

Launched by a bare `lint` in the project tool. The summary view lists rule
codes with their counts; select one to drill into its individual findings, then
go back. The listing re-runs ruff every second, and can apply auto-fixes for
the selected rule.

Keys
  j / k, ↓ / ↑   move selection
  l / → / Enter  open the selected code's findings
  h / ← / Esc    back to the summary
  g / G          jump to top / bottom
  f              apply ruff's auto-fixes for the selected code
  q              quit

Run with no TTY (e.g. piped) it prints the summary table once and exits, so it
still works in scripts.
"""

import json
import os
import re
import subprocess
import sys

from rich.text import Text
from textual import work
from textual.app import App, ComposeResult
from textual.binding import Binding
from textual.containers import Container, Horizontal, Vertical
from textual.screen import ModalScreen
from textual.widgets import Button, DataTable, Footer, Header, Label, Static

RUFF_CMD = ["uvx", "ruff", "check", "--output-format=json"]
AUTO_INTERVAL = 1.0  # seconds


# ── data ───────────────────────────────────────────────────────────────────

def run_ruff(paths):
    """Run ruff, returning (findings, error). findings is [] when clean."""
    cmd = RUFF_CMD + (paths or ["."])
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True)
    except FileNotFoundError as exc:
        return None, f"could not run {cmd[0]!r}: {exc}"
    out = proc.stdout.strip()
    if not out:
        # ruff writes nothing to stdout when there's nothing to report;
        # a non-{0,1} exit with stderr means ruff itself failed.
        if proc.returncode not in (0, 1) and proc.stderr.strip():
            return None, proc.stderr.strip()
        return [], None
    try:
        return json.loads(out), None
    except json.JSONDecodeError:
        return None, (proc.stderr.strip() or out)[:2000]


def apply_fixes(paths, code, unsafe=False):
    """Run ruff --fix limited to one code. Returns a short status line.

    Plain --fix only applies fixes ruff marks "safe"; --unsafe-fixes is needed
    to apply the rest, which is why a code can look fixable yet `f` does nothing.
    """
    cmd = ["uvx", "ruff", "check", "--fix", "--select", code]
    if unsafe:
        cmd.append("--unsafe-fixes")
    cmd += (paths or ["."])
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True)
    except FileNotFoundError as exc:
        return f"could not run ruff: {exc}", "error"
    for line in (proc.stderr or "").splitlines():
        if "fixed" in line.lower():
            return line.strip(), "information"
    return f"ran fixes for {code}", "information"


def summarize(findings):
    """Group findings by code → list of (code, info), busiest first.

    info carries the total `count` plus how many of those findings ruff can fix
    `safe`ly vs only with `unsafe` fixes — they drive different keybindings.
    """
    codes = {}
    for f in findings:
        code = f.get("code") or "unknown"
        applicability = (f.get("fix") or {}).get("applicability")
        if code not in codes:
            # drop instance-specific parenthesised detail for a cleaner label
            desc = re.sub(r"\s*\(.*?\)\s*$", "", f.get("message", ""))
            codes[code] = {"count": 0, "safe": 0, "unsafe": 0, "desc": desc}
        codes[code]["count"] += 1
        if applicability == "safe":
            codes[code]["safe"] += 1
        elif applicability == "unsafe":
            codes[code]["unsafe"] += 1
    return sorted(codes.items(), key=lambda kv: (-kv[1]["count"], kv[0]))


def findings_for(findings, code):
    rows = []
    for f in findings:
        if (f.get("code") or "unknown") != code:
            continue
        loc = f.get("location") or {}
        rows.append({
            "file": f.get("filename", "?"),
            "row": loc.get("row", 0),
            "col": loc.get("column", 0),
            "msg": f.get("message", ""),
        })
    rows.sort(key=lambda r: (r["file"], r["row"], r["col"]))
    return rows


def relpath(path):
    try:
        return os.path.relpath(path)
    except ValueError:
        return path


def clamp(v, lo, hi):
    return max(lo, min(v, hi))


def fix_label(info):
    """Short word for a code's fix availability: safe / unsafe / both / no."""
    if info["safe"] and info["unsafe"]:
        return "both"
    if info["safe"]:
        return "safe"
    if info["unsafe"]:
        return "unsafe"
    return "no"


def _fix_cell(info):
    """FIX-column marker: green ✓ for safe fixes, yellow ⚠ for unsafe ones."""
    cell = Text()
    if info["safe"]:
        cell.append("✓", style="green")
    if info["unsafe"]:
        cell.append("⚠", style="yellow")
    if not cell.plain:
        cell.append("·", style="dim")
    return cell


# ── non-interactive fallback ─────────────────────────────────────────────────

def print_summary(findings):
    rows = summarize(findings)
    print(f"{'CODE':<12} {'COUNT':>6}  {'FIX':<6}  DESCRIPTION")
    print("-" * 60)
    for code, info in rows:
        print(f"{code:<12} {info['count']:>6}  {fix_label(info):<6}  {info['desc']}")
    total = sum(info["count"] for _, info in rows)
    print(f"\n{total} total errors across {len(rows)} codes")


# ── TUI ──────────────────────────────────────────────────────────────────────

class ConfirmFix(ModalScreen[bool]):
    """Yes/no dialog before applying fixes; unsafe fixes get a louder warning.

    Dismisses with True to proceed, False to cancel. Cancel is focused by
    default so a stray Enter never applies an unsafe rewrite.
    """

    BINDINGS = [
        Binding("y", "confirm", "Apply", show=False),
        Binding("n", "cancel", "Cancel", show=False),
        Binding("escape", "cancel", "Cancel", show=False),
    ]
    # No opaque backgrounds (keeps terminal transparency); the border delimits
    # the dialog instead. $error/$primary resolve to ANSI red/blue.
    CSS = """
    ConfirmFix { align: center middle; }
    #dialog {
        width: 64;
        max-width: 90%;
        height: auto;
        padding: 1 2;
        border: round $primary;
    }
    #dialog.unsafe { border: round $error; }
    #title { text-style: bold; width: 1fr; }
    #dialog.unsafe #title { color: $error; }
    #warn { width: 1fr; margin-top: 1; }
    #buttons { height: auto; margin-top: 1; align-horizontal: right; }
    #buttons Button { margin-left: 2; }
    """

    def __init__(self, code, unsafe, count):
        super().__init__()
        self.code = code
        self.unsafe = unsafe
        self.count = count

    def compose(self) -> ComposeResult:
        kind = "unsafe" if self.unsafe else "safe"
        n = self.count
        things = "finding" if n == 1 else "findings"
        with Vertical(id="dialog", classes="unsafe" if self.unsafe else ""):
            yield Label(f"Apply {kind} fixes for {self.code}?", id="title")
            if self.unsafe:
                body = (
                    f"⚠  ruff will rewrite {n} {things} using fixes it marks UNSAFE.\n"
                    "Unsafe fixes can change what your code does. Review the diff "
                    "afterwards."
                )
            else:
                body = f"ruff will fix {n} {things}, editing files in place."
            yield Label(body, id="warn")
            with Horizontal(id="buttons"):
                yield Button("Cancel", variant="default", id="cancel")
                yield Button(
                    "Apply unsafe" if self.unsafe else "Apply",
                    variant="error" if self.unsafe else "primary",
                    id="apply",
                )

    def on_button_pressed(self, event: Button.Pressed):
        self.dismiss(event.button.id == "apply")

    def action_confirm(self):
        self.dismiss(True)

    def action_cancel(self):
        self.dismiss(False)


class RuffTui(App):
    # The "ansi-dark" theme (set in on_mount) paints every surface with the
    # terminal's *default* background (ANSI SGR 49, no explicit colour), which
    # is what lets a transparent terminal show through. So this stylesheet must
    # NOT set any opaque background — not even `transparent`, which forces an
    # RGB blend and re-opaques the cell. Foreground colours are fine; only
    # backgrounds break compositor transparency.
    CSS = """
    DataTable:ansi > .datatable--header {
        text-style: bold;
        color: $text-muted;
        background: ansi_default;
    }
    #body { height: 1fr; }
    DataTable { height: 1fr; }
    #message {
        width: 1fr;
        height: 1fr;
        content-align: center middle;
        color: $text-muted;
        text-style: bold;
    }
    """

    BINDINGS = [
        Binding("j", "cursor_down", "Down", show=False),
        Binding("k", "cursor_up", "Up", show=False),
        Binding("g", "cursor_top", "Top", show=False),
        Binding("G", "cursor_bottom", "Bottom", show=False),
        Binding("l", "open", "Open"),
        Binding("right", "open", "Open", show=False),
        Binding("h", "back", "Back"),
        Binding("left", "back", "Back", show=False),
        Binding("escape", "back", "Back", show=False),
        Binding("f", "fix", "Fix safe"),
        Binding("F", "fix_unsafe", "Fix unsafe"),
        Binding("q", "quit", "Quit"),
    ]

    def __init__(self, paths):
        super().__init__()
        self.paths = paths
        self.findings = []
        self.summary = []
        self.fix_info = {}      # code → summary info (counts, safe, unsafe)
        self.detail = []
        self.error = None
        self.mode = "summary"   # "summary" | "detail"
        self.code = None        # code being viewed in detail

    def compose(self) -> ComposeResult:
        yield Header()
        with Container(id="body"):
            yield DataTable(id="table")
            yield Static(id="message")
        yield Footer()

    def on_mount(self):
        # ANSI theme → surfaces use the terminal's default background, so
        # ghostty/compositor transparency shows through instead of being
        # painted over with an opaque RGB colour.
        self.theme = "ansi-dark"
        self.title = "ruff"
        self.table = self.query_one("#table", DataTable)
        self.table.cursor_type = "row"
        self.message = self.query_one("#message", Static)
        self.message.display = False
        self.set_interval(AUTO_INTERVAL, self.refresh_data)
        self.refresh_data()
        self.table.focus()

    # data refresh -----------------------------------------------------------
    @work(thread=True, exclusive=True, group="refresh")
    def refresh_data(self):
        findings, error = run_ruff(self.paths)
        self.call_from_thread(self._apply_results, findings, error)

    def _apply_results(self, findings, error):
        if error is not None:
            self.error = error
        else:
            self.error = None
            self.findings = findings
            self.summary = summarize(findings)
            self.fix_info = {code: info for code, info in self.summary}
            if self.mode == "detail" and self.code is not None:
                self.detail = findings_for(findings, self.code)
        self.render_state()

    # rendering --------------------------------------------------------------
    def render_state(self, cursor_row=None):
        if self.error:
            self.message.update(Text(self.error, style="red"))
            self.message.display = True
            self.table.display = False
        elif self.mode == "summary" and not self.summary:
            self.message.update("✓  no findings")
            self.message.display = True
            self.table.display = False
        elif self.mode == "detail" and not self.detail:
            self.message.update("(none)")
            self.message.display = True
            self.table.display = False
        else:
            self.message.display = False
            self.table.display = True
            self._rebuild_table(cursor_row)
        self.update_status()

    def _rebuild_table(self, cursor_row):
        t = self.table
        prev = t.cursor_row or 0
        t.clear(columns=True)
        if self.mode == "summary":
            t.add_column("CODE", width=12)
            t.add_column("COUNT", width=7)
            t.add_column("FIX", width=4)
            t.add_column("DESCRIPTION")
            for code, info in self.summary:
                count = Text(str(info["count"]), justify="right")
                t.add_row(Text(code, style="bold"), count, _fix_cell(info), info["desc"])
        else:
            t.add_column("LOCATION")
            t.add_column("MESSAGE")
            for r in self.detail:
                loc = f"{relpath(r['file'])}:{r['row']}:{r['col']}"
                t.add_row(Text(loc, style="bold cyan"), Text(r["msg"], style="dim"))
        if t.row_count:
            target = prev if cursor_row is None else cursor_row
            t.move_cursor(row=clamp(target, 0, t.row_count - 1))

    def update_status(self):
        if self.error:
            self.sub_title = "ruff error"
            return
        if self.mode == "detail" and self.code:
            self.sub_title = f"{self.code} · {len(self.detail)} findings"
        else:
            total = sum(info["count"] for _, info in self.summary)
            self.sub_title = f"{total} findings · {len(self.summary)} codes"

    # input ------------------------------------------------------------------
    def check_action(self, action, parameters):
        if action == "open" and self.mode != "summary":
            return None
        if action == "back" and self.mode != "detail":
            return None
        return True

    def current_code(self):
        if self.mode == "detail":
            return self.code
        if self.summary:
            idx = self.table.cursor_row
            if idx is not None and 0 <= idx < len(self.summary):
                return self.summary[idx][0]
        return None

    def action_cursor_down(self):
        self.table.action_cursor_down()

    def action_cursor_up(self):
        self.table.action_cursor_up()

    def action_cursor_top(self):
        if self.table.row_count:
            self.table.move_cursor(row=0)

    def action_cursor_bottom(self):
        if self.table.row_count:
            self.table.move_cursor(row=self.table.row_count - 1)

    def action_open(self):
        if self.mode != "summary" or not self.summary:
            return
        idx = self.table.cursor_row
        if idx is None or not (0 <= idx < len(self.summary)):
            return
        self.code = self.summary[idx][0]
        self.detail = findings_for(self.findings, self.code)
        self.mode = "detail"
        self.refresh_bindings()
        self.render_state(cursor_row=0)

    def on_data_table_row_selected(self, event):
        self.action_open()

    def action_back(self):
        if self.mode != "detail":
            return
        code = self.code
        self.mode = "summary"
        self.code = None
        self.refresh_bindings()
        idx = next((i for i, (c, _) in enumerate(self.summary) if c == code), 0)
        self.render_state(cursor_row=idx)

    def action_fix(self):
        self._request_fix(unsafe=False)

    def action_fix_unsafe(self):
        self._request_fix(unsafe=True)

    def _request_fix(self, unsafe):
        code = self.current_code()
        if not code:
            self.notify("nothing selected", severity="warning")
            return
        info = self.fix_info.get(code)
        if info is None:
            return
        if unsafe:
            if not info["unsafe"]:
                self.notify(f"{code} has no unsafe fixes", severity="warning")
                return
            # --unsafe-fixes applies safe and unsafe fixes together
            count = info["safe"] + info["unsafe"]
        else:
            if not info["safe"]:
                hint = " — its fixes are unsafe, use shift+F" if info["unsafe"] else ""
                self.notify(f"no safe fix available for {code}{hint}", severity="warning")
                return
            count = info["safe"]

        def proceed(ok):
            if ok:
                self.notify(f"applying {'unsafe ' if unsafe else ''}fixes for {code}…")
                self._apply_fix(code, unsafe)

        self.push_screen(ConfirmFix(code, unsafe, count), proceed)

    @work(thread=True, group="fix")
    def _apply_fix(self, code, unsafe):
        msg, severity = apply_fixes(self.paths, code, unsafe)
        self.call_from_thread(self._after_fix, msg, severity)

    def _after_fix(self, msg, severity):
        self.notify(msg, severity=severity)
        self.refresh_data()


def main():
    paths = sys.argv[1:]
    if not sys.stdout.isatty():
        findings, error = run_ruff(paths)
        if error is not None:
            print(error, file=sys.stderr)
            return 1
        print_summary(findings)
        return 0
    RuffTui(paths).run()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
