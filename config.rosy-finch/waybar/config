[
    {
        "include": "~/.config/waybar/modules.jsonc",
        "output": "HDMI-A-1",

        "modules-left": ["custom/host", "custom/project", "hyprland/workspaces", "hyprland/submap"],
        "modules-right": ["pulseaudio", "network"],
        "hyprland/workspaces": {
            "format": "{name}",
            "persistent-workspaces": {
                "*": [1, 2, 3, 4]
            }
        }
    },
    {
        "include": "~/.config/waybar/modules.jsonc",
        "output": "DP-3",

        "modules-left": ["custom/host", "custom/project", "hyprland/workspaces"],
        "modules-right": ["cpu", "memory", "temperature", "clock"],
        "hyprland/workspaces": {
            "format": "{name}",
            "persistent-workspaces": {
                "*": [5, 6, 7, 8]
            }
        }
    }
]
