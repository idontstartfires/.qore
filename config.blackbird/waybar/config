[
    {
        "include": "~/.config/waybar/modules.jsonc",
        "modules-left": ["custom/host", "custom/project", "hyprland/workspaces"],
        "modules-center": ["hyprland/submap"],
        "modules-right": [
            "pulseaudio", "network", "cpu", "memory", 
            "temperature", "backlight", "battery", "clock"
        ],
        "hyprland/workspaces": {
            "format": "{name}",
            "persistent-workspaces": {
                "*": 6
            }
        }
    }
]
