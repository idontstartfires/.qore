[
    {
        "include": "~/.config/waybar/modules.jsonc",
        "output": "HDMI-A-1",

        "modules-left": ["custom/host", "hyprland/workspaces"],
        "modules-center": ["hyprland/submap"],
        "modules-right": ["pulseaudio", "clock"],

        "hyprland/workspaces": {
            "format": "{name}",
            "persistent-workspaces": {
                "*": [1, 2, 3]
            }
        }
    },
    {
        "include": "~/.config/waybar/modules.jsonc",
        "output": "DP-2",

        "modules-left": ["custom/host", "hyprland/workspaces"],
        "modules-center": ["custom/project"],
        "modules-right": ["temperature"],

        "hyprland/workspaces": {
            "format": "{name}",
            "persistent-workspaces": {
                "*": [4, 5, 6]
            }
        }
    },
    {
        "include": "~/.config/waybar/modules.jsonc",
        "output": "DP-1",

        "modules-left": ["custom/host", "hyprland/workspaces"],
        "modules-right": ["network", "cpu", "memory", "clock"],

        "hyprland/workspaces": {
            "format": "{name}",
            "persistent-workspaces": {
                "*": [7, 8, 9]
            }
        }
    }
]
