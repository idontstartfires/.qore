{
    "layer": "top",
    "position": "top",

    "modules-left": ["custom/host", "custom/project", "hyprland/workspaces", "hyprland/submap"],
    "modules-right": [
        "pulseaudio", "network", "cpu", "memory", 
        "temperature", "backlight", "battery", "clock"
    ],

    "custom/host": {
        "format": "blackbird"
    },
    "custom/project": {
        "exec": "project show",
        "on-click": "project select",
        "interval": 1
    },
    "hyprland/workspaces": {
        "format": "{name}",
        "persistent-workspaces": {
            "*": 8
        }
    },
    "hyprland/window": {
        "format": "{}",
        "rewrite": {
            "(.*) - Firefox Developer Edition": "юЭЕ $1",
            "(.*) - fish": "> [$1]"
        },
        "separate-outputs": true
    },
    "hyprland/submap": {
        "format": "ґ░е╗  {}",
        "max-length": 16,
        "tooltip": false
    },
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y/%m/%d}"
    },
    "cpu": {
        "format": "{usage}% яЛЫ",
        "tooltip": false,
        "on-click": "$TERM -e $PROC_CTRL"
    },
    "memory": {
        "format": "{}% яГЙ",
        "on-click": "$TERM -e $PROC_CTRL"

    },
    "temperature": {
        "critical-threshold": 80,
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["яЛЛ", "яЛК", "яЛЙ", "яЛЗ"]
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ґ▒РЛ",
        "format-plugged": "{capacity}% яЗж",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) яЗл",
        "format-ethernet": "{ipaddr}/{cidr} яЮЦ",
        "tooltip-format": "{ifname} via {gwaddr} яЮЦ",
        "format-linked": "{ifname} (No IP) яЮЦ",
        "format-disconnected": "Disconnected тЪа",
        "format-alt": "{ifname} {ipaddr}"
    },
    "pulseaudio": {
        "format": "{volume}% {icon}  {format_source}",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "яЪй {format_source}",
        "format-source": "{volume}% яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "ґ░ЛЛ",
            "hands-free": "ґ░Х╣",
            "headset": "ґ░ЛО",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "$TERM -e $AUDIO_CTRL"
    },
}
