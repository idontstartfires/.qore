#!/bin/sh
# project — workspace profile manager

P=$QORE/project
profiles=$P/profiles
active=$P/active
template=$P/template
lib=$P/libexec

host=$(hostname -s)

. "$lib/ui"

_active() {
    cat "$active" 2>/dev/null
}

# Source a profile's config and optional host override
_load() {
    profile_name=${1:-$(_active)}
    [ -z "$profile_name" ] && { printf 'project: no active profile\n' >&2; exit 1; }
    config_file="$profiles/$profile_name/config"
    [ ! -f "$config_file" ] && { printf 'project: profile "%s" not found\n' "$profile_name" >&2; exit 1; }
    . "$config_file"
    [ -f "$profiles/$profile_name/config.$host" ] && . "$profiles/$profile_name/config.$host"
    return 0
}

# Sorted profile names: manifest-ordered first, untracked profiles appended
_sorted_names() {
    local tmp
    tmp=$(mktemp)
    "$lib/manifest" list | while IFS= read -r name; do
        [ -d "$profiles/$name" ] && printf '%s\n' "$name"
    done > "$tmp"
    for name in $(ls -A "$profiles" 2>/dev/null); do
        [ -d "$profiles/$name" ] || continue
        grep -q "^$name$" "$tmp" 2>/dev/null || printf '%s\n' "$name"
    done >> "$tmp"
    cat "$tmp"
    rm -f "$tmp"
}

# Try to match a query against profile names using fzf.
# Auto-selects when there is exactly one match; shows picker for multiple.
# Returns empty string if no match or fzf is unavailable.
_fuzzy_profile() {
    query=$1
    type fzf >/dev/null 2>&1 || return
    _sorted_names | fzf --query="$query" --select-1 --exit-0 --no-sort 2>/dev/null
}

# Default standard commands — overridable in any profile via cmd_<name>()
cmd_root() { printf '%s\n' "$ROOT"; }
cmd_ide()  { cd "$ROOT" && ${IDE:-nvim}; }
cmd_nav()  { ${FILE_MANAGER:-lf} "$ROOT"; }
cmd_git()  {
    if [ $# -eq 0 ] || [ "$1" = "lazy" ]; then
        (cd "$ROOT" && ${LAZYGIT:-lazygit})
    else
        git -C "$ROOT" "$@"
    fi
}

_dispatch() {
    subcmd=$1; shift
    if type "cmd_$subcmd" >/dev/null 2>&1; then
        "cmd_$subcmd" "$@"
    else
        printf 'project: no command "%s"\n' "$subcmd" >&2; exit 1
    fi
}

cmd=${1:-profile}
[ $# -gt 0 ] && shift

case $cmd in
    -h|--help|help)
        "$lib/help" "$@"; exit 0 ;;

    profile)
        "$lib/profile" "$@" ;;

    list)
        active_name=$(_active)
        tmp=$(mktemp)
        _sorted_names > "$tmp"

        max_name_width=0
        while IFS= read -r name; do
            [ ${#name} -gt $max_name_width ] && max_name_width=${#name}
        done < "$tmp"

        while IFS= read -r name; do
            activated_ts=$(grep "^$name	" "$P/manifest" 2>/dev/null | awk -F'\t' '{print $3}')
            time_ago=$(_reltime "${activated_ts:-0}")

            if [ "$name" = "$active_name" ]; then
                printf "${c_green}●${c_reset} ${c_bold}${c_green}%-${max_name_width}s${c_reset}  ${c_dim}%s${c_reset}\n" \
                    "$name" "$time_ago"
            else
                printf "  %-${max_name_width}s  ${c_dim}%s${c_reset}\n" "$name" "$time_ago"
            fi
        done < "$tmp"
        rm -f "$tmp" ;;

    set)
        profile_name=$1
        [ ! -d "$profiles/$profile_name" ] && {
            printf 'project: profile "%s" not found\n' "$profile_name" >&2; exit 1
        }
        printf '%s\n' "$profile_name" > "$active"
        "$lib/manifest" touch "$profile_name" ;;

    select)
        mode=fzf
        while [ $# -gt 0 ]; do
            case $1 in
                -m|--mode) mode=$2; shift 2 ;;
                -h|--help) "$lib/help" select; exit 0 ;;
                *) printf 'project select: unknown option "%s"\n' "$1" >&2; exit 1 ;;
            esac
        done
        case $mode in
            fzf)
                type fzf >/dev/null 2>&1 || { printf 'project select: fzf not found\n' >&2; exit 1; }
                selected=$(_sorted_names | fzf) ;;
            rofi)
                type rofi >/dev/null 2>&1 || { printf 'project select: rofi not found\n' >&2; exit 1; }
                selected=$(_sorted_names | rofi -dmenu -p "project") ;;
            wofi)
                type wofi >/dev/null 2>&1 || { printf 'project select: wofi not found\n' >&2; exit 1; }
                selected=$(_sorted_names | wofi --dmenu) ;;
            *)
                printf 'project select: unknown mode "%s" (fzf|rofi|wofi)\n' "$mode" >&2; exit 1 ;;
        esac
        [ -n "$selected" ] && project set "$selected" ;;

    root|ide|nav)
        _load; _dispatch "$cmd" "$@" ;;

    edit)
        profile_name=${1:-$(_active)}
        ${EDITOR:-nvim} "$profiles/$profile_name/config" ;;

    new)
        profile_name=$1
        [ -z "$profile_name" ] && { printf 'usage: project new <name>\n' >&2; exit 1; }
        [ -d "$profiles/$profile_name" ] && {
            printf 'project: "%s" already exists\n' "$profile_name" >&2; exit 1
        }
        mkdir -p "$profiles/$profile_name"
        cp "$template/config" "$profiles/$profile_name/config"
        "$lib/manifest" add "$profile_name"
        ${EDITOR:-nvim} "$profiles/$profile_name/config"
        project set "$profile_name" ;;

    trash)
        profile_name=${1:-$(_active)}
        [ ! -d "$profiles/$profile_name" ] && {
            printf 'project: profile "%s" not found\n' "$profile_name" >&2; exit 1
        }
        gio trash "$profiles/$profile_name"
        "$lib/manifest" mark "$profile_name" trashed
        [ "$(_active)" = "$profile_name" ] && : > "$active"
        printf 'Trashed %s (recoverable from system trash)\n' "$profile_name" ;;

    purge)
        profile_name=${1:-$(_active)}
        "$lib/manifest" remove "$profile_name"
        [ -d "$profiles/$profile_name" ] && gio trash "$profiles/$profile_name"
        [ "$(_active)" = "$profile_name" ] && : > "$active"
        printf 'Purged %s from manifest\n' "$profile_name" ;;

    recover)
        profile_name=$1
        [ -z "$profile_name" ] && { printf 'usage: project recover <name>\n' >&2; exit 1; }
        [ -d "$profiles/$profile_name" ] && {
            printf 'project: "%s" profile already exists\n' "$profile_name" >&2; exit 1
        }
        commit=$(
            git -C "$QORE" log --all --oneline -- "project/profiles/$profile_name/config" 2>/dev/null \
            | head -1 \
            | awk '{print $1}'
        )
        if [ -z "$commit" ]; then
            printf 'project: no git history found for "%s"\n' "$profile_name" >&2
            "$lib/manifest" exists "$profile_name" && \
                printf '  (in manifest — profile history unrecoverable without source files)\n'
            exit 1
        fi
        printf 'Recovering %s from commit %s...\n' "$profile_name" "$commit"
        mkdir -p "$profiles/$profile_name"
        git -C "$QORE" show "$commit:project/profiles/$profile_name/config" \
            > "$profiles/$profile_name/config"
        "$lib/manifest" add "$profile_name"
        printf 'Recovered %s\n' "$profile_name" ;;

    manifest)
        "$lib/manifest" "$@" ;;

    *)
        # cmd is a profile name, a fuzzy profile prefix, or a command on the active profile.
        # Try exact profile match first, then fuzzy, then fall through to active profile dispatch.
        if [ -d "$profiles/$cmd" ]; then
            _load "$cmd"
            subcmd=${1:-ide}; [ $# -gt 0 ] && shift
            _dispatch "$subcmd" "$@"
        else
            matched=$(_fuzzy_profile "$cmd")
            if [ -n "$matched" ]; then
                _load "$matched"
                subcmd=${1:-ide}; [ $# -gt 0 ] && shift
                _dispatch "$subcmd" "$@"
            else
                _load
                _dispatch "$cmd" "$@"
            fi
        fi ;;
esac
