#!/bin/sh
# project — workspace profile manager

lib=$QORE/project/libexec
. "$lib/common"

# ── Dispatch ──────────────────────────────────────────────────────────────────

[ $# -eq 0 ] && { "$lib/profile"; exit; }

case $1 in
    -h|--help)
        shift; "$lib/help" "$@" ;;

    -Q*)
        subflags="${1#-Q}"; shift
        [ -n "$subflags" ] && set -- "-$subflags" "$@"
        "$lib/query" "$@" ;;

    -P*)
        subflags="${1#-P}"; shift
        [ -n "$subflags" ] && set -- "-$subflags" "$@"
        "$lib/profile" "$@" ;;

    -E*)
        subflags="${1#-E}"; shift
        [ -n "$subflags" ] && set -- "-$subflags" "$@"
        "$lib/edit" "$@" ;;

    -C*)
        subflags="${1#-C}"; shift
        [ -n "$subflags" ] && set -- "-$subflags" "$@"
        "$lib/create" "$@" ;;

    -S*)
        subflags="${1#-S}"; shift
        [ -n "$subflags" ] && set -- "-$subflags" "$@"
        "$lib/select" "$@" ;;

    -R*)
        subflags="${1#-R}"; shift
        [ -n "$subflags" ] && set -- "-$subflags" "$@"
        "$lib/remove" "$@" ;;

    -A*)
        subflags="${1#-A}"; shift
        [ -n "$subflags" ] && set -- "-$subflags" "$@"
        "$lib/active" "$@" ;;

    -*)
        printf 'project: unknown flag "%s"\n' "$1" >&2; exit 1 ;;

    *)
        name=$(resolve_profile "$1") || { printf 'project: no profile matching "%s"\n' "$1" >&2; exit 1; }
        shift; source_profile "$name"
        subcmd=${1:-cd}; [ $# -gt 0 ] && shift
        dispatch "$subcmd" "$@" ;;
esac
