#!/bin/sh
# profile — display information about a project profile
#
# usage: profile [name] [-nvg] [-h]
# name defaults to the active profile when omitted

lib=$QORE/project/libexec
. "$lib/common"

# ── helpers ───────────────────────────────────────────────────────────────

show_help() {
    cat <<'EOF'
usage: profile [name] [-nvg] [-h]

display information about a project profile
name defaults to the active profile when omitted

flags (combinable, eg. -vg):
  -n   name only
  -v   verbose: created date, root, activation time
  -g   include git summary
  -h   show this help
EOF
}

git_summary() {
    project_root=$1

    git -C "$project_root" rev-parse --git-dir >/dev/null 2>&1 \
    || { printf "${c_dim}%9s${c_reset}  (not a git repo)\n" "git"; return 0; }

    branch=$(     git -C "$project_root" branch --show-current    2>/dev/null)
    last_subject=$(git -C "$project_root" log -1 --format='%s'   2>/dev/null)
    last_time=$(   git -C "$project_root" log -1 --format='%cr'  2>/dev/null)
    status_output=$(git -C "$project_root" status --porcelain     2>/dev/null)

    if [ -z "$status_output" ]; then
        change_summary="clean"
    else
        num_changed=$(  printf '%s\n' "$status_output" | grep -vc '^??')
        num_untracked=$(printf '%s\n' "$status_output" | grep  -c '^??')
        change_summary=""
        [ "$num_changed"   -gt 0 ] && change_summary="${num_changed} changed"
        [ "$num_untracked" -gt 0 ] && {
            [ -n "$change_summary" ] && change_summary="$change_summary · "
            change_summary="${change_summary}${num_untracked} untracked"
        }
    fi

    printf "${c_dim}%9s${c_reset}  %s\n"                         "branch"  "$branch"
    printf "${c_dim}%9s${c_reset}  %s ${c_dim}(%s)${c_reset}\n" "last"    "$last_subject" "$last_time"

    if [ "$change_summary" = "clean" ]; then
        printf "${c_dim}%9s  clean${c_reset}\n" "changes"
    else
        printf "${c_dim}%9s${c_reset}  ${c_yellow}%s${c_reset}\n" "changes" "$change_summary"
    fi
}

# ── argument parsing ──────────────────────────────────────────────────────

profile_name=""
name_only=false
verbose=false
include_git=false

while [ $# -gt 0 ]; do
    case $1 in
        --help)
            show_help; exit 0 ;;
        --name)
            [ -n "$2" ] || { printf 'profile: --name requires a value\n' >&2; exit 1; }
            [ -z "$profile_name" ] || { printf 'profile: name already specified\n' >&2; exit 1; }
            profile_name=$2; shift 2 ;;
        -*)
            remaining_flags="${1#-}"
            shift
            while [ -n "$remaining_flags" ]; do
                flag="${remaining_flags%"${remaining_flags#?}"}"
                remaining_flags="${remaining_flags#?}"
                case $flag in
                    h) show_help; exit 0 ;;
                    n) name_only=true ;;
                    v) verbose=true ;;
                    g) include_git=true ;;
                    *) printf 'profile: unknown flag "-%s"\n' "$flag" >&2; exit 1 ;;
                esac
            done ;;
        *)
            if [ -z "$profile_name" ]; then
                profile_name=$1
            else
                printf 'profile: unexpected argument "%s"\n' "$1" >&2; exit 1
            fi
            shift ;;
    esac
done

[ -z "$profile_name" ] && profile_name=$(active_profile)
[ -z "$profile_name" ] && { printf 'profile: no active profile\n' >&2; exit 1; }
profile_name=$(resolve_profile "$profile_name") \
    || { printf 'profile: "%s" not found\n' "$profile_name" >&2; exit 1; }

config_file="$profiles/$profile_name/init"

# ── name only ─────────────────────────────────────────────────────────────

if $name_only; then
    printf '%s\n' "$profile_name"
    exit 0
fi

# ── collect data ──────────────────────────────────────────────────────────

# Source the config in a subshell to expand variables (eg. $HOME in ROOT)
project_root=$(. "$config_file" 2>/dev/null; printf '%s' "$ROOT")
root_display=$(  printf '%s' "$project_root" | sed "s|^$HOME|~|")

meta_file="$profiles/$profile_name/.meta"
created=$(     grep '^created='   "$meta_file" 2>/dev/null | cut -d= -f2)
activated_ts=$(grep '^activated=' "$meta_file" 2>/dev/null | cut -d= -f2)
time_ago=$(reltime "${activated_ts:-0}")

# ── verbose view ──────────────────────────────────────────────────────────

if $verbose; then
    printf "${c_dim}%9s${c_reset}  ${c_bold}%s${c_reset}\n" "profile"   "$profile_name"
    printf "${c_dim}%9s${c_reset}  %s\n"                    "root"      "$root_display"
    printf "${c_dim}%9s${c_reset}  %s\n"                    "created"   "$created"
    printf "${c_dim}%9s${c_reset}  %s\n"                    "activated" "$time_ago"
    if $include_git; then git_summary "$project_root"; fi
    exit 0
fi

# ── default pretty view ───────────────────────────────────────────────────

printf "${c_bold}${c_green}%s${c_reset}  %s\n" "$profile_name" "$time_ago"

if $include_git; then git_summary "$project_root"; fi
