#!/bin/sh
# project help

lib=$QORE/project/libexec
. "$lib/common"

cmd=${1:-}

case $cmd in
    '')
        cat <<'EOF'
usage: project [flags] [args]

  -Q[s]        query profiles                  (-Qh for options)
  -P[nvg]      inspect a profile               (-Ph for options)
  -S[m]        set or select active profile    (-Sh for options)
  -A [subcmd]  dispatch to active profile      (default: ide)

  -C[fra]      create or restore profile       (-Ch for options)
  -E [name]    edit profile init (or a named file within it)
  -M [name]    list modules, or edit/create one (-Mh for options)
  -R           trash profile                   (-Rh for options)
  -h [profile] show this help, or list commands for a profile
EOF
        ;;
    *)
        name=$(resolve_profile "$cmd") \
            || { printf 'help: no profile matching "%s"\n' "$cmd" >&2; exit 1; }
        init="$profiles/$name/init"
        # Collect modules the profile imports via `use`, so their commands show too.
        module_files=""
        for m in $(sed -n 's/^[[:space:]]*use[[:space:]]\{1,\}//p' "$init" 2>/dev/null); do
            [ -f "$modules/$m" ] && module_files="$module_files $modules/$m"
        done
        printf '%s — commands\n' "$name"
        grep -h '^cmd_[a-zA-Z_]* *()' "$lib/defaults" $module_files "$init" 2>/dev/null \
            | sed 's/ *(.*$//' \
            | sed 's/^cmd_//' \
            | awk '!seen[$0]++'
        ;;
esac
