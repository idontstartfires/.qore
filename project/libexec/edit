#!/bin/sh
# edit — open a profile file in the editor

lib=$QORE/project/libexec
. "$lib/common"

show_help() {
    cat <<'EOF'
usage: project -E [name] [file]

open a file from a profile directory in $EDITOR

  -E               edit active profile's init
  -E <name>        edit named profile's init (fuzzy match)
  -E <name> <file> edit (or create) a specific file in the profile directory

options:
  -h    show this help

examples:
  project -E                      open active profile's init
  project -E farm                 open farmchain's init (fuzzy)
  project -E farmchain secrets.env  open (or create) farmchain/secrets.env
EOF
}

# ── argument parsing ──────────────────────────────────────────────────────────

profile_name=""
file_name=""

while [ $# -gt 0 ]; do
    case $1 in
        -h|--help) show_help; exit 0 ;;
        -*)
            remaining="${1#-}"; shift
            while [ -n "$remaining" ]; do
                flag="${remaining%"${remaining#?}"}"
                remaining="${remaining#?}"
                case $flag in
                    h) show_help; exit 0 ;;
                    *) printf 'edit: unknown flag "-%s"\n' "$flag" >&2; exit 1 ;;
                esac
            done ;;
        *)
            if [ -z "$profile_name" ]; then
                profile_name=$1
            elif [ -z "$file_name" ]; then
                file_name=$1
            else
                printf 'edit: unexpected argument "%s"\n' "$1" >&2; exit 1
            fi
            shift ;;
    esac
done

# ── resolve profile ───────────────────────────────────────────────────────────

[ -z "$profile_name" ] && profile_name=$(active_profile)
[ -z "$profile_name" ] && { printf 'edit: no active profile\n' >&2; exit 1; }
profile_name=$(resolve_profile "$profile_name") \
    || { printf 'edit: no profile matching "%s"\n' "$profile_name" >&2; exit 1; }

# ── open file ────────────────────────────────────────────────────────────────

target="$profiles/$profile_name/${file_name:-init}"

# Stub new secondary files so the editor opens an existing file
if [ -n "$file_name" ] && [ ! -f "$target" ]; then
    printf '# %s\n' "$file_name" > "$target"
fi

cd "$profiles"
${EDITOR:-nvim} "$target"
