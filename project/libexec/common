#!/bin/sh
# common — shared variables and utilities, sourced by project modules

P=$QORE/project
profiles=$P/profiles
active=$P/.active
lib=$P/libexec

# ── UI ────────────────────────────────────────────────────────────────────────

if [ -t 1 ]; then
    c_reset='[0m'
    c_bold='[1m'
    c_dim='[2m'
    c_green='[32m'
    c_yellow='[33m'
else
    c_reset='' c_bold='' c_dim='' c_green='' c_yellow=''
fi

reltime() {
    local timestamp delta now
    timestamp=${1:-0}
    [ "$timestamp" -eq 0 ] 2>/dev/null && { printf 'never'; return; }
    now=$(date +%s); delta=$((now - timestamp))
    if   [ $delta -lt 60 ];     then printf 'just now'
    elif [ $delta -lt 3600 ];   then printf '%dm ago' $((delta / 60))
    elif [ $delta -lt 86400 ];  then printf '%dh ago' $((delta / 3600))
    elif [ $delta -lt 604800 ]; then printf '%dd ago' $((delta / 86400))
    else                             printf '%dw ago' $((delta / 604800))
    fi
}

# ── Profile utilities ─────────────────────────────────────────────────────────

# Print the name of the currently active profile, or nothing if unset.
active_profile() { cat "$active" 2>/dev/null; }

# Print profile names sorted by last activation (most recent first).
profile_names() { "$lib/query" list; }

# Print the profile name that best matches the query via fzf; return 1 if none.
fuzzy_profile() {
    type fzf >/dev/null 2>&1 || return 1
    profile_names | fzf --query="$1" --select-1 --exit-0 --no-sort 2>/dev/null
}

# Resolve an exact or fuzzy profile name; print it and return 0, or return 1.
# Callers are responsible for printing an error message on failure.
resolve_profile() {
    local query=$1 matched
    [ -d "$profiles/$query" ] && { printf '%s' "$query"; return 0; }
    matched=$(fuzzy_profile "$query") || return 1
    printf '%s' "$matched"
}

# Source a profile's init file, preceded by defaults.
# Requires an exact profile name — does not fall back to the active profile.
source_profile() {
    local name=$1 init
    init="$profiles/$name/init"
    [ ! -f "$init" ] && { printf 'project: profile "%s" not found\n' "$name" >&2; exit 1; }
    . "$lib/defaults"
    . "$init"
}

# Dispatch to a cmd_<subcmd> function defined by defaults or the profile init.
dispatch() {
    local subcmd=$1; shift
    if type "cmd_$subcmd" >/dev/null 2>&1; then
        "cmd_$subcmd" "$@"
    else
        printf 'project: no command "%s"\n' "$subcmd" >&2; exit 1
    fi
}
