#!/bin/sh
# manifest — project manifest helper
# TSV format: name, created, activated, status

filepath=$QORE/project/manifest

_row()  { grep "^$1	" "$filepath" 2>/dev/null; }
_data() { grep -v '^#' "$filepath" 2>/dev/null; }

cmd=${1:-show}
[ $# -gt 0 ] && shift

case $cmd in
    list)
        # Active entries sorted by activated desc; unactivated (0) sink last
        _data | grep '	active$' | sort -t'	' -k3 -rn | awk -F'\t' '{print $1}' ;;

    show)
        grep -v '^#' "$filepath" | column -t -s'	' ;;

    add)
        n=$1
        _row "$n" >/dev/null && exit 0
        printf '%s\t%s\t0\tactive\n' "$n" "$(date +%Y-%m-%d)" >> "$filepath" ;;

    touch)
        n=$1
        if ! _row "$n" >/dev/null; then
            printf '%s\t%s\t0\tactive\n' "$n" "$(date +%Y-%m-%d)" >> "$filepath"
        fi
        now=$(date +%s)
        sed -i "s/^\($n	[^	]*	\)[^	]*/\1$now/" "$filepath" ;;

    mark)
        n=$1 val=$2
        sed -i "s/^\($n	[^	]*	[^	]*	\).*/\1$val/" "$filepath" ;;

    remove)
        n=$1
        sed -i "/^$n	/d" "$filepath" ;;

    exists)
        _row "$1" >/dev/null ;;

    get)
        n=$1
        case ${2:-status} in
            name)      col=1 ;; created)   col=2 ;;
            activated) col=3 ;; status)    col=4 ;;
            *) echo "manifest: unknown field '${2}'" >&2; exit 1 ;;
        esac
        _row "$n" | awk -F'\t' "{print \$$col}" ;;
esac
